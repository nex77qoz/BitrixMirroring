# ===== Telegram =====
TELEGRAM_BOT_TOKEN=ЗАМЕНИТЬ

# ===== Bitrix webhook =====
BITRIX_WEBHOOK_BASE=https://КОМПАНИЯ.bitrix24.ru/rest/1/ЗАМЕНИТЬ

# ===== Bitrix chat bot mode =====
BITRIX_BOT_CLIENT_ID=ЗАМЕНИТЬ
#BITRIX_BOT_ID=
# Для server-side/app.py можно также использовать отдельное имя переменной:
#BITRIX_CLIENT_ID=

# ===== Telegram <-> Bitrix chat mapping =====
# Рекомендуемый формат:
# CHAT_MAPPINGS=[{"tg_chat_id": -1001234567890, "bitrix_dialog_id": "chat2941"}]
CHAT_MAPPINGS=

# Legacy-режим для одной связки:
BITRIX_DIALOG_ID=chat2941
ALLOWED_TELEGRAM_CHAT_ID=

# ===== Optional SOCKS5 proxy =====
ENABLE_SOCKS5_PROXY=false
SOCKS5_PROXY_URL=

# ===== Formatting / behavior =====
PREFIX_WITH_CHAT_TITLE=true
PREFIX_WITH_SENDER=true
PREFIX_WITH_TIMESTAMP=true
BITRIX_DISABLE_LINK_PREVIEW=true
REQUEST_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO

# ===== Sync settings =====
BITRIX_POLL_INTERVAL_SECONDS=5
SYNC_TELEGRAM_TO_BITRIX=true
SYNC_BITRIX_TO_TELEGRAM=true
BITRIX_CURSOR_STATE_PATH=/opt/bitrix-bot/bitrix_cursor_state.json
MIRROR_STATE_DB_PATH=/opt/bitrix-bot/mirror_state.sqlite3

# ===== Internal Bitrix -> mirror bridge =====
BITRIX_WEBHOOK_BRIDGE_ENABLED=true
MIRROR_INTERNAL_BASE_URL=http://127.0.0.1:8090
MIRROR_INTERNAL_EVENT_PATH=/internal/bitrix/event
MIRROR_INTERNAL_WEBHOOK_SECRET=ЗАМЕНИТЬ_СЕКРЕТ
MIRROR_INTERNAL_TIMEOUT_SECONDS=10
BITRIX_FORWARDED_EVENTS=ONIMBOTMESSAGEADD,ONIMBOTJOINCHAT

# ===== Optional Telegram webhook mode in main.py =====
MIRROR_HTTP_HOST=127.0.0.1
MIRROR_HTTP_PORT=8090
TELEGRAM_WEBHOOK_ENABLED=false
TELEGRAM_WEBHOOK_PUBLIC_URL=https://bot.example.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=true
TELEGRAM_WEBHOOK_STRICT_VERIFY=true

# ===== Retry / performance =====
BITRIX_RETRY_ATTEMPTS=4
BITRIX_RETRY_BASE_DELAY_SECONDS=1
BITRIX_RETRY_MAX_DELAY_SECONDS=15
BITRIX_POLL_ERROR_BACKOFF_SECONDS=2
BITRIX_POLL_MAX_BACKOFF_SECONDS=30
BITRIX_USER_CACHE_TTL_SECONDS=300
BITRIX_MAX_CONCURRENT_REQUESTS=5
BITRIX_SEND_QUEUE_MAXSIZE=1000
BITRIX_SEND_WORKERS=2
BITRIX_RESCAN_RECENT_MESSAGES_LIMIT=100
