# Telegram
TELEGRAM_BOT_TOKEN=ЗАМЕНИТЬ

# Опционально. SOCKS5 proxy для Telegram и Bitrix HTTP-клиента.
# false = прокси выключен, true = прокси включен.
ENABLE_SOCKS5_PROXY=false
# Укажите URL только если ENABLE_SOCKS5_PROXY=true.
SOCKS5_PROXY_URL=

BITRIX_WEBHOOK_BASE=https://КОМПАНИЯ.bitrix24.ru/rest/1/ЗАМЕНИТЬ

# ===== Чат-бот Bitrix24 =====
# BITRIX_BOT_CLIENT_ID — CLIENT_ID, указанный при регистрации бота методом imbot.register. Обязателен.
BITRIX_BOT_CLIENT_ID=ЗАМЕНИТЬ
# BOT_ID можно не указывать, если в приложении зарегистрирован только один бот,
# но для стабильности лучше явно задать.
#BITRIX_BOT_ID=

# ===== Маппинг чатов: Telegram <-> Bitrix =====
# Связки чатов управляются через дашборд мониторинга (/monitor).
# После добавления связки перезапустите сервис Mirror.

# Форматирование / поведение
PREFIX_WITH_CHAT_TITLE=true
PREFIX_WITH_SENDER=true
BITRIX_DISABLE_LINK_PREVIEW=true
REQUEST_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO

# Интервал опроса Bitrix для зеркалирования ответов обратно в Telegram
BITRIX_POLL_INTERVAL_SECONDS=5

# Включает мгновенный Bitrix -> Telegram bridge через внутренний HTTP endpoint main.py.
# При включении server-side/app.py должен уметь достучаться до main.py по localhost.
BITRIX_WEBHOOK_BRIDGE_ENABLED=false

# Встроенный HTTP listener основного процесса mirror-service.
MIRROR_HTTP_HOST=127.0.0.1
MIRROR_HTTP_PORT=8090
MIRROR_INTERNAL_EVENT_PATH=/internal/bitrix/event

# Общий секрет для server-side/app.py -> main.py internal webhook bridge.
MIRROR_INTERNAL_WEBHOOK_SECRET=

# Telegram webhook mode. Если false, Telegram остаётся на polling.
TELEGRAM_WEBHOOK_ENABLED=false
TELEGRAM_WEBHOOK_PUBLIC_URL=https://bot.example.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=true
TELEGRAM_WEBHOOK_STRICT_VERIFY=true

# Можно отключать направления по отдельности
SYNC_TELEGRAM_TO_BITRIX=true
SYNC_BITRIX_TO_TELEGRAM=true

# SQLite state для маппинга Telegram <-> Bitrix и ревизий Bitrix без хранения текста сообщений
MIRROR_STATE_DB_PATH=mirror_state.sqlite3

# Retry/backoff для Bitrix API
BITRIX_RETRY_ATTEMPTS=4
BITRIX_RETRY_BASE_DELAY_SECONDS=1
BITRIX_RETRY_MAX_DELAY_SECONDS=15

# Самовосстановление polling loop после ошибок
BITRIX_POLL_ERROR_BACKOFF_SECONDS=2
BITRIX_POLL_MAX_BACKOFF_SECONDS=30

# Ограничение параллельных HTTP-запросов в Bitrix
BITRIX_MAX_CONCURRENT_REQUESTS=5

# Очередь и число воркеров для отправки Telegram -> Bitrix
BITRIX_SEND_QUEUE_MAXSIZE=1000
BITRIX_SEND_WORKERS=2

# На каждом цикле Bitrix polling дополнительно пересматриваем последние N сообщений,
# чтобы находить edit/delete без хранения текста сообщений
BITRIX_RESCAN_RECENT_MESSAGES_LIMIT=100

# ===== Лимиты файлов =====
# Максимальный размер одного файла (в байтах; по умолчанию 100 МБ)
MAX_FILE_SIZE_BYTES=104857600
# Директория для файлового кэша (пусто = кэширование отключено)
FILE_CACHE_DIR=
# Максимальный общий размер файлового кэша (по умолчанию 10 ГБ)
FILE_CACHE_MAX_BYTES=10737418240

# ===== Очистка БД =====
# Удалять связи сообщений старше N секунд (по умолчанию 7 дней = 604800)
DB_CLEANUP_MAX_AGE_SECONDS=604800

# Маршрут Bitrix -> Telegram использует этот chat_id как целевой чат
# Если поле пустое, обратная синхронизация отключается
